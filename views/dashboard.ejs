<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>

  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <link rel="stylesheet" href="/css/style.css">

  <style>
    body {
      background: #0f0f0f;
      color: white;
      font-family: Arial, sans-serif;
      padding: 30px;
    }

    .dashboard-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 40px;
    }

    .dashboard-header h1 {
      color: #39ff14;
      font-size: 2.2rem;
    }

    .top-buttons {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 12px 20px;
      border-radius: 10px;
      background: #39ff14;
      color: black;
      text-decoration: none;
      font-weight: bold;
      transition: 0.3s;
    }

    .btn:hover {
      transform: translateY(-3px);
      background: white;
    }

    h2 {
      margin: 40px 0 20px;
      color: #39ff14;
    }

    /* GRID */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 25px;
    }

    /* CARD */
    .card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      backdrop-filter: blur(12px);
      border-radius: 20px;
      overflow: hidden;
      transition: 0.4s;
      box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .card:hover {
      transform: translateY(-8px);
    }

    .card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
    }

    .card-content {
      padding: 20px;
    }

    .card-content h3 {
      color: #39ff14;
      margin-bottom: 10px;
    }

    .card-content p {
      color: #ccc;
      line-height: 1.6;
      margin-bottom: 15px;
    }

    .card-buttons {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .live-btn {
      background: #39ff14;
      color: black;
      padding: 10px 15px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: bold;
    }

    .delete-btn {
      background: crimson;
      color: white;
      border: none;
      padding: 10px 15px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
    }

    .delete-btn:hover {
      background: red;
    }

    /* TESTIMONIAL */
    .testimonial-top {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-bottom: 15px;
    }

    .testimonial-top img {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid #39ff14;
    }

    .rating {
      color: gold;
      margin-top: 5px;
    }

    /* MOBILE */
    @media(max-width:768px) {

      body {
        padding: 20px;
      }

      .dashboard-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 20px;
      }

      .top-buttons {
        width: 100%;
      }

      .btn {
        flex: 1;
        text-align: center;
      }

    }
  </style>
</head>

<body>

  <!-- HEADER -->
  <div class="dashboard-header">

    <h1>
      <i class="fas fa-user-shield"></i>
      Admin Dashboard
    </h1>

    <div class="top-buttons">

      <a href="/add-project" class="btn">
        <i class="fas fa-plus"></i>
        Add Project
      </a>

      <a href="/add-testimonial" class="btn">
        <i class="fas fa-comment"></i>
        Add Testimonial
      </a>

      <a href="/logout" class="btn">
        <i class="fas fa-sign-out-alt"></i>
        Logout
      </a>

    </div>

  </div>

  <!-- PROJECTS -->
  <h2>
    <i class="fas fa-code"></i>
    Projects
  </h2>

  <div class="grid">

    <% projects.forEach(project => { %>

      <div class="card">

        <img src="<%= project.image %>" alt="">

        <div class="card-content">

          <h3><%= project.title %></h3>

          <p>
            <%= project.description.length > 120
            ? project.description.substring(0,120) + "..."
            : project.description %>
          </p>

          <div class="card-buttons">

            <a href="<%= project.liveLink %>"
              target="_blank"
              class="live-btn">

              <i class="fas fa-external-link-alt"></i>
              Live

            </a>

            <form
              action="/delete-project/<%= project._id %>?_method=DELETE"
              method="POST">

              <button class="delete-btn">

                <i class="fas fa-trash"></i>
                Delete

              </button>

            </form>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

  <!-- TESTIMONIALS -->
  <h2>
    <i class="fas fa-star"></i>
    Testimonials
  </h2>

  <div class="grid">

    <% testimonials.forEach(t => { %>

      <div class="card">

        <div class="card-content">

          <div class="testimonial-top">

            <% if(t.photo){ %>

              <img src="<%= t.photo %>" alt="">

            <% } else { %>

              <img src="https://i.imgur.com/HeIi0wU.png" alt="">

            <% } %>

            <div>

              <h3><%= t.clientName %></h3>

              <div class="rating">
                ⭐ <%= t.rating %>/5
              </div>

            </div>

          </div>

          <p>
            "<%= t.message %>"
          </p>

          <form
            action="/delete-testimonial/<%= t._id %>?_method=DELETE"
            method="POST">

            <button class="delete-btn">

              <i class="fas fa-trash"></i>
              Delete

            </button>

          </form>

        </div>

      </div>

    <% }) %>

  </div>

</body>
</html>